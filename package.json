{
  "name": "finops-detective",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "localstack:up": "docker compose -f docker-compose.localstack.yml up -d",
    "localstack:down": "docker compose -f docker-compose.localstack.yml down",
    "localstack:restart": "docker compose -f docker-compose.localstack.yml down && docker compose -f docker-compose.localstack.yml up -d",
    "localstack:logs": "docker exec aegis-localstack awslocal logs describe-log-groups --query logGroups[].logGroupName --output table",
    "localstack:s3": "docker exec aegis-localstack awslocal s3 ls s3://finops-athena-results/ --recursive",
    "localstack:seed": "node scripts/localstack/seed.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-athena": "^3.650.0",
    "@aws-sdk/client-cloudwatch-logs": "^3.650.0",
    "@aws-sdk/client-s3": "^3.650.0",
    "@google/generative-ai": "^0.24.1",
    "@langchain/anthropic": "^1.3.25",
    "@langchain/core": "^1.1.36",
    "@langchain/google-genai": "^2.1.26",
    "@langchain/groq": "^1.1.5",
    "@langchain/langgraph": "^1.2.6",
    "@react-three/fiber": "8.17.10",
    "@supabase/supabase-js": "^2.45.0",
    "@tremor/react": "^3.18.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "@upstash/vector": "^1.1.0",
    "cal-sans": "^1.0.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.7.0",
    "motion": "^12.38.0",
    "next": "14.2.0",
    "next-themes": "^0.4.6",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.5.0",
    "three": "0.160.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/three": "0.160.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.5.0"
  }
}
